@page "/students"
@inject IStudentService StudentService

<PageTitle>Students</PageTitle>
<h1>Students</h1>

<div class="mb-3">
    <input class="form-control" placeholder="Search by name..." @bind="_search" @bind:event="oninput" />
</div>

<div class="row">
    <div class="col-lg-7">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>GPA</th>
                    <th>Enrollment</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (_students is null)
                {
                    <tr><td colspan="5"><em>Loading...</em></td></tr>
                }
                else if (!FilteredStudents.Any())
                {
                    <tr><td colspan="5"><em>No matching students.</em></td></tr>
                }
                else
                {
                    @foreach (var student in FilteredStudents)
                    {
                        <tr>
                            <td>@student.Name</td>
                            <td>@student.Email</td>
                            <td>@student.Gpa</td>
                            <td>@student.EnrollmentDate.ToShortDateString()</td>
                            <td class="text-nowrap">
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => Edit(student.Id)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(student.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="col-lg-5">
        <EditForm Model="_formModel" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-2">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="_formModel.Name" />
            </div>
            <div class="mb-2">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="_formModel.Email" />
            </div>
            <div class="mb-2">
                <label class="form-label">GPA</label>
                <InputNumber class="form-control" @bind-Value="_formModel.Gpa" />
            </div>
            <div class="mb-3">
                <label class="form-label">Enrollment Date</label>
                <InputDate class="form-control" @bind-Value="_formModel.EnrollmentDate" />
            </div>
            <button type="submit" class="btn btn-primary me-2">Save</button>
            <button type="button" class="btn btn-secondary" @onclick="ResetForm">New</button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <p class="mt-3 alert alert-info">@_message</p>
        }
    </div>
</div>

@code {
    private List<Student>? _students;
    private Student _formModel = new() { EnrollmentDate = DateTime.Today };
    private string _search = string.Empty;
    private string? _message;

    private IEnumerable<Student> FilteredStudents =>
        string.IsNullOrWhiteSpace(_search)
            ? _students ?? []
            : (_students ?? []).Where(s => s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _students = await StudentService.GetAllAsync();
    }

    private async Task Save()
    {
        await StudentService.AddOrUpdateAsync(_formModel);
        _message = _formModel.Id == 0 ? "Student created." : "Student updated.";
        ResetForm();
        await LoadAsync();
    }

    private async Task Delete(int id)
    {
        await StudentService.DeleteAsync(id);
        _message = "Student deleted.";
        await LoadAsync();
    }

    private void Edit(int id)
    {
        var student = _students?.FirstOrDefault(s => s.Id == id);
        if (student is null)
        {
            return;
        }

        _formModel = new Student
        {
            Id = student.Id,
            Name = student.Name,
            Email = student.Email,
            Gpa = student.Gpa,
            EnrollmentDate = student.EnrollmentDate
        };
    }

    private void ResetForm()
    {
        _formModel = new Student { EnrollmentDate = DateTime.Today };
    }
}
