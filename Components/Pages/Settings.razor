@page "/settings"

<PageTitle>Settings</PageTitle>
<h1>Settings</h1>

<div class="card p-3" style="max-width: 420px;">
    <div class="mb-3">
        <label class="form-label">Theme</label>
        <select class="form-select" @bind="_theme">
            <option value="Light">Light</option>
            <option value="Dark">Dark</option>
        </select>
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="compact" @bind="_compactMode" />
        <label class="form-check-label" for="compact">
            Compact mode
        </label>
    </div>

    <button class="btn btn-primary" @onclick="Save">Save</button>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <p class="alert alert-success mt-3">@_message</p>
    }
</div>

@code {
    private string _theme = "Light";
    private bool _compactMode;
    private string? _message;

    private void Save()
    {
        _message = $"Saved. Theme: {_theme}, Compact mode: {_compactMode}";
    }
}
